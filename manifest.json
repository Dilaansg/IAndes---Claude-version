{
  "manifest_version": 3,
  "name": "IAndes",
  "version": "5.0",
  "description": "Reduce la huella hídrica y de carbono de tus chats con IA. Comprime y mejora prompts localmente con servidor Python.",

  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],

  "host_permissions": [
    "*://chat.openai.com/*",
    "*://chatgpt.com/*",
    "*://claude.ai/*",
    "*://gemini.google.com/*",
    "http://localhost:8000/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "*://chat.openai.com/*",
        "*://chatgpt.com/*",
        "*://claude.ai/*",
        "*://gemini.google.com/*"
      ],
      "js": [
        "error_utils.js",
        "config.js",
        "token_utils.js",
        "content-provider.js",
        "content-state.js",
        "content-metrics.js",
        "content-pipeline.js",
        "content-overlay.js",
        "content-panels.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "IAndes v5 – Comprime tu prompt"
  },

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}